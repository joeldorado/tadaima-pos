APP_NAME=Tadaima
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── BASE DE DATOS ────────────────────────────────────────────────────────────
# Default: SQLite (cero configuración para dev local).
# El archivo `database/database.sqlite` se crea solo con `php artisan migrate`.
DB_CONNECTION=sqlite
# DB_DATABASE=

# ── Alternativa: MySQL / Cloud SQL (solo prod o dev avanzado) ────────────────
# Para usar MySQL local o Cloud SQL Auth Proxy, comenta DB_CONNECTION=sqlite
# y descomenta el bloque siguiente:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=tadaimaposlite
# DB_USERNAME=tadaima_app
# DB_PASSWORD=
# DB_SOCKET=  # En Cloud Run: /cloudsql/<project>:<region>:<instance>

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Sanctum / SPA — landing en :5173 envía cookies al backend en :8000
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

BROADCAST_CONNECTION=log

# ── STORAGE DE IMÁGENES ──────────────────────────────────────────────────────
# Local: disco 'public' (las imágenes se guardan en storage/app/public).
# Requiere `php artisan storage:link` una vez para exponerlas en /storage/.
# Producción Cloud Run: deploy.sh inyecta FILESYSTEM_DISK=gcs automáticamente.
FILESYSTEM_DISK=public

# Google Cloud Storage — DEJAR EN BLANCO en local. Solo para prod.
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_STORAGE_BUCKET=
# GOOGLE_CLOUD_KEY_FILE=  # ruta a service-account JSON, solo fuera de GCP

QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@tadaima.mx"
MAIL_FROM_NAME="Tadaima POS"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Tadaima Loyalty (Supabase) ───────────────────────────────────────────────
# Solo lectura desde el POS — nunca escribir/migrar sin aprobación explícita.
# En local puede quedar VACÍO: la búsqueda externa de socios simplemente no
# devolverá resultados, pero el resto del POS funciona normal.
TADAIMA_SUPABASE_URL=
TADAIMA_SUPABASE_SERVICE_KEY=
