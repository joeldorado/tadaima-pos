APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tadaimaposlite
DB_USERNAME=tadaima_app
DB_PASSWORD=

# For local dev via Cloud SQL Auth Proxy, use DB_HOST=127.0.0.1:3306 (TCP)
# For production (Cloud Run), set DB_SOCKET=/cloudsql/impusodigitaldorado:us-west1:pos-lite-db
# DB_SOCKET=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Local dev: usar disco 'public' (php artisan storage:link).
# Producción (Cloud Run): deploy.sh inyecta FILESYSTEM_DISK=gcs automáticamente.
FILESYSTEM_DISK=public

# Google Cloud Storage — dejar en blanco en local si no tienes credenciales GCP
GOOGLE_CLOUD_PROJECT_ID=impusodigitaldorado
GOOGLE_CLOUD_STORAGE_BUCKET=tadaima-media
# GOOGLE_CLOUD_KEY_FILE=/path/to/keyfile.json  # solo necesario fuera de GCP
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@poslite.com.mx"
MAIL_FROM_NAME="Tadaima POS"
# Producción: cambiar MAIL_MAILER a smtp / mailgun / sendgrid y llenar credenciales

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── Tadaima Loyalty (Supabase) ────────────────────────────────────────────────
# URL base de la REST API de Supabase (sin /rest/v1)
TADAIMA_SUPABASE_URL=https://tfbhysypjuoadgnwjaba.supabase.co
# service_role key — bypassa RLS. Nunca exponer en el frontend.
TADAIMA_SUPABASE_SERVICE_KEY=
