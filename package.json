{
  "name": "tadaima",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "landing",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "turbo run dev --filter=@tadaima/web",
    "dev:mobile": "turbo run start --filter=@tadaima/mobile",
    "build:web": "turbo run build --filter=@tadaima/web",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
